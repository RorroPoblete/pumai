generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Platform Config (global settings, managed by superadmin) ───

model PlatformConfig {
  key   String @id
  value String @db.Text
}

// ─── Auth ───

enum GlobalRole {
  USER
  SUPERADMIN
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  emailVerified DateTime?
  password      String?
  image         String?
  onboarded     Boolean    @default(false)
  role          GlobalRole @default(USER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  business    Business?
  memberships BusinessMember[]
  accounts    Account[]
  sessions    Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Business ───

model Business {
  id        String   @id @default(cuid())
  name      String
  website   String?
  industry  String
  phone     String?
  timezone  String   @default("Australia/Sydney")
  plan      Plan     @default(STARTER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  members        BusinessMember[]
  invitations    Invitation[]
  agents         Agent[]
  conversations  Conversation[]
  smsNumbers     SmsNumber[]
  channelConfigs ChannelConfig[]
}

// ─── Multi-tenancy ───

enum BusinessRole {
  OWNER
  ADMIN
  MEMBER
}

model BusinessMember {
  id        String       @id @default(cuid())
  role      BusinessRole @default(MEMBER)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model Invitation {
  id        String       @id @default(cuid())
  email     String
  role      BusinessRole @default(MEMBER)
  token     String       @unique @default(cuid())
  expiresAt DateTime
  accepted  Boolean      @default(false)
  createdAt DateTime     @default(now())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([email, businessId])
}

enum Plan {
  STARTER
  GROWTH
  ENTERPRISE
}

// ─── AI Agents ───

model Agent {
  id             String      @id @default(cuid())
  name           String
  tone           AgentTone   @default(PROFESSIONAL)
  status         AgentStatus @default(DRAFT)
  systemPrompt   String?     @db.Text
  knowledgeBase  String?     @db.Text
  industry       String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  conversations  Conversation[]
  channelConfigs ChannelConfig[]
}

enum AgentTone {
  PROFESSIONAL
  FRIENDLY
  CASUAL
}

enum AgentStatus {
  ACTIVE
  PAUSED
  DRAFT
}

// ─── SMS Numbers ───

model SmsNumber {
  id         String   @id @default(cuid())
  number     String   @unique
  provider   String   @default("160.com.au")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  conversations Conversation[]
}

// ─── Channels ───

enum Channel {
  MESSENGER
  INSTAGRAM
  WEBCHAT
  WHATSAPP
  SMS
}

model ChannelConfig {
  id          String   @id @default(cuid())
  channel     Channel
  active      Boolean  @default(true)
  externalId  String
  credentials String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, channel])
  @@index([channel, externalId])
}

// ─── Conversations ───

model Conversation {
  id                String             @id @default(cuid())
  channel           Channel            @default(SMS)
  contactName       String?
  contactPhone      String?
  contactExternalId String?
  status            ConversationStatus @default(ACTIVE)
  sentiment         Sentiment          @default(NEUTRAL)
  messagesCount     Int                @default(0)
  lastMessageAt     DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  smsNumberId String?
  smsNumber   SmsNumber? @relation(fields: [smsNumberId], references: [id])

  messages Message[]

  @@unique([businessId, channel, contactExternalId])
  @@index([businessId, channel, status])
}

enum ConversationStatus {
  ACTIVE
  RESOLVED
  ESCALATED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// ─── Messages ───

model Message {
  id            String      @id @default(cuid())
  content       String      @db.Text
  role          MessageRole
  externalMsgId String?
  createdAt     DateTime    @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
}
