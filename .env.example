# ─── PumAI environment template ───
# Copy to .env and fill in real values. The .env file is gitignored.
# web/.env.local is a symlink to this file (single source of truth).
#
# Production: inject secrets via a managed provider (Doppler, Vault, etc).

# ─── Database ───
POSTGRES_USER=pumai
# openssl rand -hex 24   (avoid /, +, ?, # — they break URLs)
POSTGRES_PASSWORD=
POSTGRES_DB=pumai_db
# Local dev points to localhost; docker-compose overrides this for app container
DATABASE_URL=postgresql://pumai:<POSTGRES_PASSWORD>@localhost:5432/pumai_db

# ─── Redis ───
# openssl rand -base64 24
REDIS_PASSWORD=
REDIS_URL=redis://default:<REDIS_PASSWORD>@localhost:6379

# ─── Auth ───
# openssl rand -base64 32
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── AI ───
OPENAI_API_KEY=

# ─── Meta (Messenger + Instagram) ───
META_APP_SECRET=
META_APP_SECRET_IG=
META_WEBHOOK_VERIFY_TOKEN=

# ─── WhatsApp (Whapi.cloud) ───
WHATSAPP_WEBHOOK_TOKEN=

# ─── Stripe ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_WEBCHAT_STARTER=
STRIPE_PRICE_WEBCHAT_GROWTH=
STRIPE_PRICE_WEBCHAT_ENTERPRISE=
STRIPE_PRICE_WEBCHAT_ADDON=
STRIPE_PRICE_WA_STARTER=
STRIPE_PRICE_WA_GROWTH=
STRIPE_PRICE_WA_ENTERPRISE=
STRIPE_PRICE_WA_ADDON=
STRIPE_PRICE_IG_STARTER=
STRIPE_PRICE_IG_GROWTH=
STRIPE_PRICE_IG_ENTERPRISE=
STRIPE_PRICE_IG_ADDON=
STRIPE_PRICE_MSG_STARTER=
STRIPE_PRICE_MSG_GROWTH=
STRIPE_PRICE_MSG_ENTERPRISE=
STRIPE_PRICE_MSG_ADDON=

# ─── Crypto keys (required, 32 bytes base64) ───
# openssl rand -base64 32
CHANNEL_CRED_KEY=
UPLOAD_SIGNING_KEY=
# Optional comma-separated old keys for decryption-only fallback during rotation
CHANNEL_CRED_KEYS=

# ─── Optional ───
# LOG_LEVEL=info
# AUTH_TRUST_HOST=true   # Set in docker-compose app service
